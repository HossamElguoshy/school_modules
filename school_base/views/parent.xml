<odoo>
    <data>

        <record id="parent_form" model="ir.ui.view">
            <field name="name">parent.form</field>
            <field name="model">school.parent</field>
            <field name="arch" type="xml">
                <form string="ModelTitle">
                    <sheet>

                        <group>
                            <group>
                                    <field name="partner_id"/>

                            </group>
                            <group>
                                <field name="child_ids" widget="many2many_tags"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="parent_tree" model="ir.ui.view">
            <field name="name">parent.tree</field>
            <field name="model">school.parent</field>
            <field name="arch" type="xml">
                <list string="Parents">
                    <field name="partner_id"/>
                    <field name="child_ids" widget="many2many_tags"/>
                </list>
            </field>
        </record>

        <record id="parent_act_window" model="ir.actions.act_window">
            <field name="name">ModelTitle</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">school.parent</field>

            <field name="view_mode">list,form</field>

        </record>



    </data>
</odoo>