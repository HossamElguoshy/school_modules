<odoo>
    <data>
        <!-- Tree View for Teachers -->
        <record id="teacher_tree" model="ir.ui.view">
            <field name="name">teacher.tree</field>
            <field name="model">school.teacher</field>
            <field name="arch" type="xml">
                <list string="Teachers">
                    <field name="employee_id"/>
                    <field name="subject_id"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <!-- Form View for Teachers -->
        <record id="teacher_form" model="ir.ui.view">
            <field name="name">teacher.form</field>
            <field name="model">school.teacher</field>
            <field name="arch" type="xml">
                <form string="Teacher">
                    <sheet>
                        <div class="oe_title">
                            <label for="employee_id"/>
                            <h1>
                                <field name="employee_id"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="subject_id"/>
                                <field name="active"/>
                            </group>
                            <group>
                                <field name="class_ids" widget="many2many_tags"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action Window for Teachers -->
        <record id="teacher_act_window" model="ir.actions.act_window">
            <field name="name">Teachers</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">school.teacher</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
