<odoo>

    <record id="view_school_fee_list" model="ir.ui.view">
        <field name="name">school.fee.list</field>
        <field name="model">school.fee</field>

        <field name="arch" type="xml">
            <list>

                <field name="student_id"/>
                <field name="total_amount"/>
                <field name="invoice_id"/>

            </list>
        </field>
    </record>


    <record id="view_school_fee_form" model="ir.ui.view">
        <field name="name">school.fee.form</field>
        <field name="model">school.fee</field>

        <field name="arch" type="xml">
            <form>

                <sheet>

                    <header>

                        <button
                            name="action_create_invoice"
                            type="object"
                            string="Create Invoice"
                            class="btn-primary"/>

                    </header>

                    <group>

                        <field name="student_id"/>
                        <field name="total_amount" readonly="1"/>
                        <field name="invoice_id"/>

                    </group>

                    <notebook>

                        <page string="Fee Lines">

                            <field name="fee_line_ids">

                                <list editable="bottom">

                                    <field name="fee_structure_id"/>
                                    <field name="amount"/>

                                </list>

                            </field>

                        </page>

                    </notebook>

                 </sheet>



            </form>
        </field>
    </record>


    <record id="action_school_fee" model="ir.actions.act_window">
        <field name="name">Student Fees</field>
        <field name="res_model">school.fee</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>