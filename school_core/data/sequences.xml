<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="seq_school_student" model="ir.sequence">
    <field name="name">Student Code</field>
    <field name="code">school.student</field>
    <field name="prefix">STU/</field>
    <field name="padding">5</field>
    <field name="company_id" eval="False"/>
  </record>
     <record id="seq_school_application" model="ir.sequence">
    <field name="name">Application</field>
    <field name="code">school.application</field>
    <field name="prefix">APP/</field>
    <field name="padding">5</field>
    <field name="company_id" eval="False"/>
  </record>


</odoo>