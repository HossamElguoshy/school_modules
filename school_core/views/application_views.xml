<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <record id="view_school_application_list" model="ir.ui.view">
      <field name="name">school.application.list</field>
      <field name="model">school.application</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="student_name"/>
          <field name="guardian_partner_id"/>
          <field name="academic_year_id"/>
          <field name="grade_id"/>
          <field name="section_id"/>
          <field name="state"/>
          <field name="create_date"/>
        </list>
      </field>
    </record>

    <record id="view_school_application_form" model="ir.ui.view">
      <field name="name">school.application.form</field>
      <field name="model">school.application</field>
      <field name="arch" type="xml">
        <form>
          <header>
            <button name="action_submit" type="object" string="Submit" class="btn-primary"
                   />
            <button name="action_review" type="object" string="Mark Under Review"
                    />
            <button name="action_accept_create_student" type="object" string="Accept  Create Student"
                    class="btn-success"/>
            <button name="action_reject" type="object" string="Reject" class="btn-secondary"
                   />
            <field name="state" widget="statusbar" statusbar_visible="draft,submitted,review,accepted,rejected"/>
          </header>

          <sheet>
            <group>
              <group>
                <field name="name" readonly="1"/>
                <field name="guardian_partner_id"/>
              </group>
              <group>
                <field name="academic_year_id"/>
                <field name="grade_id"/>
                <field name="section_id" domain="[('grade_id','=',grade_id)]"/>
              </group>
            </group>

            <group string="Student Information">
              <group>
                <field name="student_name"/>
                <field name="student_birthdate"/>
              </group>
              <group>
                <field name="student_id" invisible="1"/>
              </group>
            </group>

            <notebook>
              <page string="Documents">
                <field name="attachment_ids" widget="many2many_binary"/>
              </page>
              <page string="Notes">
                <field name="note"/>
              </page>
              <page string="Chatter">
                <field name="message_follower_ids" widget="mail_followers"/>
                <field name="message_ids" widget="mail_thread"/>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>

    <record id="action_school_application" model="ir.actions.act_window">
      <field name="name">Applications</field>
      <field name="res_model">school.application</field>
      <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_school_application" name="Applications"
              parent="menu_school_admissions" action="action_school_application" sequence="10"/>

  </data>
</odoo>