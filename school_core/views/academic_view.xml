<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- Academic Year -->
    <record id="view_school_academic_year_" model="ir.ui.view">
      <field name="name">school.academic.year.list</field>
      <field name="model">school.academic.year</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="date_start"/>
          <field name="date_end"/>
          <field name="active"/>
        </list>
      </field>
    </record>

    <record id="view_school_academic_year_form" model="ir.ui.view">
      <field name="name">school.academic.year.form</field>
      <field name="model">school.academic.year</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="name"/>
              <field name="date_start"/>
              <field name="date_end"/>
              <field name="active"/>
            </group>
            <notebook>
              <page string="Terms">
                <field name="term_ids">
                  <list editable="bottom">
                    <field name="name"/>
                    <field name="date_start"/>
                    <field name="date_end"/>
                    <field name="active"/>
                  </list>
                </field>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>

    <record id="action_school_academic_year" model="ir.actions.act_window">
      <field name="name">Academic Years</field>
      <field name="res_model">school.academic.year</field>
      <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_school_academic_year" name="Academic Years"
              parent="menu_school_configuration" action="action_school_academic_year" sequence="10"/>


    <!-- Grades -->
    <record id="view_school_grade_" model="ir.ui.view">
      <field name="name">school.grade.list</field>
      <field name="model">school.grade</field>
      <field name="arch" type="xml">
        <list>
          <field name="sequence" widget="handle"/>
          <field name="name"/>
          <field name="code"/>
          <field name="active"/>
        </list>
      </field>
    </record>

    <record id="view_school_grade_form" model="ir.ui.view">
      <field name="name">school.grade.form</field>
      <field name="model">school.grade</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="name"/>
              <field name="code"/>
              <field name="sequence"/>
              <field name="active"/>
            </group>
            <notebook>
              <page string="Sections">
                <field name="section_ids">
                  <list editable="bottom">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="capacity"/>
                    <field name="active"/>
                  </list>
                </field>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>

    <record id="action_school_grade" model="ir.actions.act_window">
      <field name="name">Grades</field>
      <field name="res_model">school.grade</field>
      <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_school_grade" name="Grades"
              parent="menu_school_configuration" action="action_school_grade" sequence="20"/>


    <!-- Sections -->
    <record id="view_school_section_" model="ir.ui.view">
      <field name="name">school.section.list</field>
      <field name="model">school.section</field>
      <field name="arch" type="xml">
        <list>
          <field name="grade_id"/>
          <field name="sequence" widget="handle"/>
          <field name="name"/>
          <field name="capacity"/>
          <field name="student_count"/>
          <field name="active"/>
        </list>
      </field>
    </record>

    <record id="view_school_section_form" model="ir.ui.view">
      <field name="name">school.section.form</field>
      <field name="model">school.section</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="grade_id"/>
              <field name="name"/>
              <field name="sequence"/>
              <field name="capacity"/>
              <field name="active"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record id="action_school_section" model="ir.actions.act_window">
      <field name="name">Sections</field>
      <field name="res_model">school.section</field>
      <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_school_section" name="Sections"
              parent="menu_school_configuration" action="action_school_section" sequence="30"/>


    <!-- Subjects -->
    <record id="view_school_subject_" model="ir.ui.view">
      <field name="name">school.subject.list</field>
      <field name="model">school.subject</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="code"/>
          <field name="active"/>
        </list>
      </field>
    </record>

    <record id="view_school_subject_form" model="ir.ui.view">
      <field name="name">school.subject.form</field>
      <field name="model">school.subject</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="name"/>
              <field name="code"/>
              <field name="active"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record id="action_school_subject" model="ir.actions.act_window">
      <field name="name">Subjects</field>
      <field name="res_model">school.subject</field>
      <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_school_subject" name="Subjects"
              parent="menu_school_configuration" action="action_school_subject" sequence="40"/>

  </data>
</odoo>