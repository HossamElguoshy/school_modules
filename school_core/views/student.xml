<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <record id="view_school_student_list" model="ir.ui.view">
      <field name="name">school.student.list</field>
      <field name="model">school.student</field>
      <field name="arch" type="xml">
        <list>
          <field name="student_code"/>
          <field name="name"/>
          <field name="grade_id"/>
          <field name="section_id"/>
          <field name="academic_year_id"/>
          <field name="state"/>
          <field name="active"/>
        </list>
      </field>
    </record>

    <record id="view_school_student_form" model="ir.ui.view">
      <field name="name">school.student.form</field>
      <field name="model">school.student</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <div class="oe_button_box" name="button_box">
              <button
                name="action_view_contact"
                type="object"
                class="oe_stat_button"
                icon="fa-address-card">
                <div class="o_stat_info">
                  <span class="o_stat_text">Contact</span>
                </div>
              </button>
            </div>

            <div class="oe_title">
              <h1>
                <field name="name" placeholder="Student Name"/>
              </h1>
            </div>

            <group>
              <group>
                <field name="student_code" readonly="1"/>
                <field name="partner_id"/>
                <field name="invoice_partner_id" readonly="1"/>
              </group>
              <group>
                <field name="academic_year_id"/>
                <field name="grade_id"/>
                <field name="section_id" domain="[('grade_id', '=', grade_id)]"/>
                <field name="state"/>
                <field name="active"/>
              </group>
            </group>

            <notebook>
              <page string="Guardians">
                <field name="guardian_partner_ids" widget="many2many_tags"/>
              </page>

              <page string="Notes">
                <field name="message_follower_ids" widget="mail_followers"/>
                <field name="message_ids" widget="mail_thread"/>
              </page>
            </notebook>
          </sheet>
          <chatter/>

        </form>
      </field>
    </record>

    <record id="action_school_student" model="ir.actions.act_window">
      <field name="name">Students</field>
      <field name="res_model">school.student</field>
      <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_school_student" name="Students"
              parent="menu_school_students" action="action_school_student" sequence="10"/>

  </data>
</odoo>
