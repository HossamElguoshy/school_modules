<odoo>
    <data>
        <!-- Tree View for Grades -->
        <record id="grade_tree" model="ir.ui.view">
            <field name="name">grade.tree</field>
            <field name="model">school.grade</field>
            <field name="arch" type="xml">
                <list string="Grades">
                    <field name="student_id"/>
                    <field name="subject_id"/>
                    <field name="teacher_id"/>
                    <field name="exam_date"/>
                    <field name="score"/>
                    <field name="percentage"/>
                </list>
            </field>
        </record>

        <!-- Form View for Grades -->
        <record id="grade_form" model="ir.ui.view">
            <field name="name">grade.form</field>
            <field name="model">school.grade</field>
            <field name="arch" type="xml">
                <form string="Grade">
                    <sheet>
                        <group>
                            <group>
                                <field name="student_id"/>
                                <field name="subject_id"/>
                                <field name="teacher_id"/>
                            </group>
                            <group>
                                <field name="exam_date"/>
                                <field name="score"/>
                                <field name="max_score"/>
                                <field name="percentage" readonly="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action Window for Grades -->
        <record id="grade_act_window" model="ir.actions.act_window">
            <field name="name">Grades</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">school.grade</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
