<odoo>
    <data>
        <!-- Tree View for Subjects -->
        <record id="subject_list" model="ir.ui.view">
            <field name="name">subject_list</field>
            <field name="model">school.subject</field>
            <field name="arch" type="xml">
                <list string="Subjects">
                    <field name="name"/>
                </list>
            </field>
        </record>

        <!-- Form View for Subjects -->
        <record id="subject_form" model="ir.ui.view">
            <field name="name">subject.form</field>
            <field name="model">school.subject</field>
            <field name="arch" type="xml">
                <form string="Subject">
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="teacher_ids">
                                    <list>
                                        <field name="employee_id"/>
                                        <field name="active"/>
                                    </list>
                                </field>
                            </group>
                            <group>
                                <field name="class_ids" widget="many2many_tags"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action Window for Subjects -->
        <record id="subject_act_window" model="ir.actions.act_window">
            <field name="name">Subjects</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">school.subject</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
