<odoo>

    <!-- My Students -->
    <template id="portal_my_students" name="My Students">
    <t t-call="portal.portal_layout">
        <div class="container mt-4 mb-5">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="mb-0">My Children</h2>
            </div>

            <t t-if="students">
                <div class="card shadow-sm">
                    <div class="card-body p-0">
                        <table class="table table-striped table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Name</th>
                                    <th>Student Code</th>
                                    <th>Grade</th>
                                    <th>Section</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="students" t-as="student">
                                    <tr>
                                        <td><t t-esc="student.name"/></td>
                                        <td><t t-esc="student.student_code or ''"/></td>
                                        <td><t t-esc="student.grade_id.name or ''"/></td>
                                        <td><t t-esc="student.section_id.name or ''"/></td>
                                        <td>
                                            <a t-att-href="'/my/student/%s' % student.id"
                                               class="btn btn-primary btn-sm">
                                                View Details
                                            </a>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>
            </t>
            <t t-else="">
                <div class="alert alert-info mt-3">
                    No students found.
                </div>
            </t>
        </div>
    </t>
</template>

    <!-- Student Details -->
    <template id="portal_student_detail" name="Student Details">
    <t t-call="portal.portal_layout">
        <div class="container mt-4 mb-5">

            <!-- Header -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="mb-1">
                        <t t-esc="student.name"/>
                    </h2>
                    <p class="text-muted mb-0">
                        Student Code:
                        <strong><t t-esc="student.student_code or ''"/></strong>
                    </p>
                </div>
                <div>
                    <a href="/my/students" class="btn btn-outline-secondary btn-sm">
                        Back to My Children
                    </a>
                </div>
            </div>

            <!-- Student Information Card -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h4 class="mb-0">Student Information</h4>
                </div>
                <div class="card-body p-0">
                    <table class="table table-striped mb-0">
                        <tbody>
                            <tr>
                                <td width="30%"><strong>Academic Year</strong></td>
                                <td><t t-esc="student.academic_year_id.name or ''"/></td>
                            </tr>
                            <tr>
                                <td><strong>Grade</strong></td>
                                <td><t t-esc="student.grade_id.name or ''"/></td>
                            </tr>
                            <tr>
                                <td><strong>Section</strong></td>
                                <td><t t-esc="student.section_id.name or ''"/></td>
                            </tr>
                            <tr>
                                <td><strong>Invoice To</strong></td>
                                <td><t t-esc="student.invoice_partner_id.name or ''"/></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Exam Results -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h4 class="mb-0">Exam Results</h4>
                </div>
                <div class="card-body p-0">
                    <t t-if="exams">
                        <table class="table table-bordered table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Exam</th>
                                    <th>Subject</th>
                                    <th>Mark</th>
                                    <th>Max Mark</th>
                                    <th>Percentage</th>
                                    <th>Status</th>
                                    <th>Grade</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="exams" t-as="e">
                                    <tr>
                                        <td><t t-esc="e.exam_id.name"/></td>
                                        <td><t t-esc="e.exam_id.subject_id.name or ''"/></td>
                                        <td><t t-esc="e.mark"/></td>
                                        <td><t t-esc="e.max_mark"/></td>
                                        <td><t t-esc="e.percentage"/>%</td>
                                        <td>
                                            <t t-if="e.status == 'pass'">
                                                <span class="badge bg-success">Pass</span>
                                            </t>
                                            <t t-else="">
                                                <span class="badge bg-danger">Fail</span>
                                            </t>
                                        </td>
                                        <td>
                                            <span class="badge bg-primary">
                                                <t t-esc="e.grade_letter or ''"/>
                                            </span>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>
                    <t t-else="">
                        <div class="p-3 text-muted">
                            No exam results available.
                        </div>
                    </t>
                </div>
            </div>

            <!-- Attendance -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h4 class="mb-0">Attendance</h4>
                </div>
                <div class="card-body p-0">
                    <t t-if="attendance_lines">
                        <table class="table table-bordered table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Date</th>
                                    <th>Status</th>
                                    <th>Note</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="attendance_lines" t-as="att">
                                    <tr>
                                        <td><t t-esc="att.session_id.date"/></td>
                                        <td>
                                            <t t-if="att.status == 'present'">
                                                <span class="badge bg-success">Present</span>
                                            </t>
                                            <t t-elif="att.status == 'absent'">
                                                <span class="badge bg-danger">Absent</span>
                                            </t>
                                            <t t-elif="att.status == 'late'">
                                                <span class="badge bg-warning text-dark">Late</span>
                                            </t>
                                            <t t-else="">
                                                <span class="badge bg-info text-dark">Excused</span>
                                            </t>
                                        </td>
                                        <td><t t-esc="att.note or ''"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>
                    <t t-else="">
                        <div class="p-3 text-muted">
                            No attendance records available.
                        </div>
                    </t>
                </div>
            </div>

            <!-- Fees -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h4 class="mb-0">Fees</h4>
                </div>
                <div class="card-body p-0">
                    <t t-if="fees">
                        <table class="table table-bordered table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Total Amount</th>
                                    <th>Status</th>
                                    <th>Invoice</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="fees" t-as="fee">
                                    <tr>
                                        <td><t t-esc="fee.total_amount"/></td>
                                        <td>
                                            <span class="badge bg-secondary">
                                                <t t-esc="fee.state"/>
                                            </span>
                                        </td>
                                        <td>
                                            <t t-if="fee.invoice_id">
                                                <t t-esc="fee.invoice_id.name"/>
                                            </t>
                                            <t t-else="">No Invoice</t>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>
                    <t t-else="">
                        <div class="p-3 text-muted">
                            No fee records available.
                        </div>
                    </t>
                </div>
            </div>

            <!-- Invoices -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h4 class="mb-0">Invoices</h4>
                </div>
                <div class="card-body p-0">
                    <t t-if="invoices">
                        <table class="table table-bordered table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Number</th>
                                    <th>Total</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="invoices" t-as="inv">
                                    <tr>
                                        <td><t t-esc="inv.name"/></td>
                                        <td><t t-esc="inv.amount_total"/></td>
                                        <td>
                                            <span class="badge bg-dark">
                                                <t t-esc="inv.payment_state"/>
                                            </span>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>
                    <t t-else="">
                        <div class="p-3 text-muted">
                            No invoices available.
                        </div>
                    </t>
                </div>
            </div>

        </div>
    </t>
</template>

    <!-- Add button on portal home -->
    <template id="portal_menu_inherit" inherit_id="portal.portal_my_home">
        <xpath expr="//div[@id='portal_common_category']" position="after">
            <div class="mt-3">
                <a href="/my/students" class="btn btn-primary btn-block">
                    My Children
                </a>
            </div>
        </xpath>
    </template>

</odoo>