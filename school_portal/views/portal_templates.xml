<odoo>
<template id="portal_my_students" name="My Students">
    <t t-call="portal.portal_layout">

        <h2>My Children</h2>

        <table class="table table-striped">
            <tr>
                <th>Name</th>
                <th></th>
            </tr>

            <t t-foreach="students" t-as="student">
                <tr>
                    <td><t t-esc="student.name"/></td>
                    <td>
                        <a t-att-href="'/my/student/%s' % student.id"
                           class="btn btn-primary btn-sm">
                            View
                        </a>
                    </td>
                </tr>
            </t>

        </table>

    </t>
</template>


<template id="portal_student_detail" name="Student Details">
    <t t-call="portal.portal_layout">

        <h2><t t-esc="student.name"/></h2>

        <!-- Exams -->
        <h3>Exam Results</h3>

        <table class="table table-bordered">
            <tr>
                <th>Subject</th>
                <th>Mark</th>
                <th>Status</th>
            </tr>

            <t t-foreach="exams" t-as="e">
                <tr>
                    <td><t t-esc="e.exam_id.subject_id.name"/></td>
                    <td><t t-esc="e.mark"/></td>
                    <td>
                        <t t-if="e.status == 'pass'">
                            <span class="text-success">Pass</span>
                        </t>
                        <t t-else="">
                            <span class="text-danger">Fail</span>
                        </t>
                    </td>
                </tr>
            </t>
        </table>

        <!-- Fees -->
        <h3>Invoices</h3>

        <table class="table table-bordered">
            <tr>
                <th>Number</th>
                <th>Total</th>
                <th>Status</th>
            </tr>

            <t t-foreach="invoices" t-as="inv">
                <tr>
                    <td><t t-esc="inv.name"/></td>
                    <td><t t-esc="inv.amount_total"/></td>
                    <td><t t-esc="inv.payment_state"/></td>
                </tr>
            </t>
        </table>

    </t>
</template>

<template id="portal_menu_inherit" inherit_id="portal.portal_my_home">
    <xpath expr="//div[@id='portal_common_category']" position="after">
        <div class="mt-3">
            <a href="/my/students" class="btn btn-primary btn-block">
                My Children
            </a>
        </div>
    </xpath>
</template>
</odoo>
